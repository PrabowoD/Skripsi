@article{Sanchez2018,
abstract = {In this work, we present an implementation and thorough study of the Harris corner detector. This feature detector relies on the analysis of the eigenvalues of the autocorrelation matrix. The algorithm comprises seven steps, including several measures for the classification of corners, a generic non-maximum suppression method for selecting interest points, and the possibility to obtain the corners position with subpixel accuracy. We study each step in detail and propose several alternatives for improving the precision and speed. The experiments analyze the repeatability rate of the detector using different types of transformations.},
author = {S{\'{a}}nchez, Javier and Monz{\'{o}}n, Nelson and Salgado, Agust{\'{i}}n},
doi = {10.5201/ipol.2018.229},
issn = {21051232},
journal = {Image Processing On Line},
keywords = {Autocorrelation matrix,Feature detector,Harris corner,Interest point,Non-maximum suppression},
number = {March},
pages = {305--328},
title = {{An analysis and implementation of the harris corner detector}},
volume = {8},
year = {2018}
}
